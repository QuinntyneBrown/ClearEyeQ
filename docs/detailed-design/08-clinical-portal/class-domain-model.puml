@startuml
skinparam defaultFontSize 11
skinparam classAttributeIconSize 0
skinparam linetype ortho

title Clinical Portal - Domain Model

package "Clinical Portal Domain" {

    class ClinicalUser <<Entity>> {
        + TenantId : Guid
        + UserId : Guid
        + FullName : string
        + Specialty : string
        + LicenseNumber : string
        + IsActive : bool
    }

    class PatientAssignment <<Aggregate Root>> {
        + AssignmentId : Guid
        + TenantId : Guid
        + ClinicalUserId : Guid
        + PatientId : Guid
        + AssignedAt : DateTimeOffset
        + Status : AssignmentStatus
        --
        + Reassign(newClinicianId) : void
        + Deactivate() : void
    }

    class ReferralCase <<Aggregate Root>> {
        + ReferralId : Guid
        + TenantId : Guid
        + PatientId : Guid
        + AssignedClinicianId : Guid?
        + EscalationReason : string
        + Urgency : UrgencyLevel
        + Status : ReferralStatus
        + CreatedAt : DateTimeOffset
        --
        + Accept(clinicianId) : void
        + Decline(clinicianId, reason) : void
    }

    class TreatmentReviewTask <<Aggregate Root>> {
        + ReviewId : Guid
        + TenantId : Guid
        + TreatmentPlanId : Guid
        + PatientId : Guid
        + AssignedClinicianId : Guid?
        + ReviewType : TreatmentReviewType
        + Status : TreatmentReviewStatus
        + CreatedAt : DateTimeOffset
        --
        + Approve(clinicianId, rationale) : void
        + Reject(clinicianId, reason) : void
    }

    class ClinicalNote <<Aggregate Root>> {
        + NoteId : Guid
        + TenantId : Guid
        + PatientId : Guid
        + AuthorId : Guid
        + Content : string
        + NoteType : ClinicalNoteType
        + CreatedAt : DateTimeOffset
        --
        + Amend(content) : void
    }

    class PatientSummaryReadModel <<Read Model>> {
        + TenantId : Guid
        + PatientId : Guid
        + FullName : string
        + LastScanDate : DateTimeOffset?
        + LatestDiagnosis : string?
        + RiskLevel : string?
    }

    class ScanResultReadModel <<Read Model>> {
        + TenantId : Guid
        + ScanId : Guid
        + PatientId : Guid
        + ScanType : string
        + CapturedAt : DateTimeOffset
        + QualityScore : decimal
    }

    class DiagnosticReadModel <<Read Model>> {
        + TenantId : Guid
        + DiagnosticId : Guid
        + PatientId : Guid
        + Condition : string
        + Confidence : decimal
        + GeneratedAt : DateTimeOffset
    }

    class TreatmentPlanReadModel <<Read Model>> {
        + TenantId : Guid
        + TreatmentPlanId : Guid
        + PatientId : Guid
        + PlanSummary : string
        + Status : string
        + CreatedAt : DateTimeOffset
    }

    class TreatmentReviewReadModel <<Read Model>> {
        + TenantId : Guid
        + ReviewId : Guid
        + TreatmentPlanId : Guid
        + PatientId : Guid
        + ReviewType : string
        + Status : string
        + CreatedAt : DateTimeOffset
    }

    enum TreatmentReviewType {
        InitialPlan
        MedicationAdjustment
    }

    enum TreatmentReviewStatus {
        Pending
        Approved
        Rejected
    }
}

ClinicalUser "1" -- "*" PatientAssignment : manages >
ClinicalUser "1" -- "*" ReferralCase : reviews >
ClinicalUser "1" -- "*" TreatmentReviewTask : approves >
ClinicalUser "1" -- "*" ClinicalNote : authors >
PatientSummaryReadModel .. ScanResultReadModel : references
PatientSummaryReadModel .. DiagnosticReadModel : references
TreatmentPlanReadModel .. TreatmentReviewReadModel : references

@enduml
