@startuml
skinparam defaultFontSize 11
skinparam sequenceArrowThickness 1
skinparam maxMessageSize 180

title Referral Flow - AI Escalation to Clinician Resolution

actor "Clinician" as clinician
participant "React Frontend" as react
participant "BFF API" as bff
participant "Processed Message\nStore" as inbox
participant "MediatR" as mediatr
participant "ReferralCase\nRepository" as repo
participant "Integration\nOutbox" as outbox
participant "Outbox Relay" as relay
database "PostgreSQL" as db
participant "Azure\nService Bus" as bus
participant "Notification\nContext" as notify

== Escalation Recommended (from Treatment Context) ==

bus -> bff : EscalationRecommended event
activate bff
bff -> inbox : TryBegin(eventId)
inbox --> bff : first delivery
bff -> mediatr : CreateReferralCommand
mediatr -> repo : Create ReferralCase
repo -> db : INSERT referral_cases
repo --> mediatr : ReferralCase created
mediatr -> outbox : Append(ReferralCreated)
relay -> outbox : Poll pending records
relay -> bus : Publish(ReferralCreated)
bus -> notify : ReferralCreated event
notify -> clinician : Push notification:\n"New AI-escalated referral"
deactivate bff

== Clinician Reviews Referral ==

clinician -> react : Open Referral Inbox
react -> bff : GET /api/referrals?status=Pending
bff -> mediatr : GetReferralInboxQuery
mediatr -> db : SELECT pending referrals
db --> mediatr : referral list
mediatr --> bff : List<ReferralDto>
bff --> react : 200 OK (referrals)
react --> clinician : Display referral list

== Clinician Accepts Referral ==

clinician -> react : Click "Accept Referral"
react -> bff : POST /api/referrals/{id}/accept
activate bff
bff -> mediatr : AcceptReferralCommand
mediatr -> repo : Load ReferralCase
repo -> db : SELECT referral
repo --> mediatr : ReferralCase
mediatr -> repo : referral.Accept(clinicianId)
repo -> db : UPDATE status = Accepted
mediatr -> outbox : Append(ReferralAccepted)
relay -> outbox : Poll pending records
relay -> bus : Publish(ReferralAccepted)
deactivate bff

bus -> notify : ReferralAccepted event
notify -> clinician : In-app confirmation
notify --> react : SignalR: referral status updated

@enduml
