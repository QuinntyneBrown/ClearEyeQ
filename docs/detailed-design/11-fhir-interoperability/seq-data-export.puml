@startuml
skinparam defaultFontSize 11
skinparam sequenceArrowThickness 1
skinparam maxMessageSize 180

title FHIR Data Export Flow - Patient Right of Access

actor "Patient" as patient
participant "Web App" as app
participant "FHIR API" as api
participant "MediatR" as mediatr
participant "Export Worker" as worker
participant "Scan\nRead Service" as scan
participant "Diagnostic\nRead Service" as diag
participant "Treatment\nRead Service" as treat
participant "FHIR Mappers" as mappers
participant "FHIR\nValidator" as validator
participant "Azure Blob\nStorage" as blob
database "PostgreSQL" as db

== Patient Requests Data Export ==

patient -> app : Request "Export My Data"
app -> api : POST /api/fhir/export
api -> mediatr : ExportPatientDataCommand
mediatr -> db : INSERT export_jobs\n(status=Queued)
mediatr --> api : 202 Accepted\n(jobId)
api --> app : Export job started

== Background Export Processing ==

worker -> db : SELECT next queued export job
db --> worker : ExportJob(jobId, patientId)

worker -> scan : GetScansByPatient(patientId)
scan --> worker : List<ScanResult>

worker -> diag : GetDiagnosticsByPatient(patientId)
diag --> worker : List<DiagnosticResult>

worker -> treat : GetTreatmentPlans(patientId)
treat --> worker : List<TreatmentPlan>

== Map to FHIR Resources ==

worker -> mappers : MapToPatient(profile)
mappers --> worker : FHIR Patient

worker -> mappers : MapToObservations(scans)
mappers --> worker : List<FHIR Observation>

worker -> mappers : MapToDiagnosticReports(diagnostics)
mappers --> worker : List<FHIR DiagnosticReport>

worker -> mappers : MapToMedicationRequests(plans)
mappers --> worker : List<FHIR MedicationRequest>

== Validate & Package ==

worker -> validator : Validate(bundle)
validator --> worker : ValidationResult (pass)

worker -> mappers : CreateBundle(allResources)
mappers --> worker : FHIR Bundle (JSON)

== Store & Deliver ==

worker -> blob : Upload bundle.json\n(encrypted)
blob --> worker : Blob name / object key

worker -> db : UPDATE export_jobs\n(status=Completed, blobName)

patient -> app : Check export status
app -> api : GET /api/fhir/export/{jobId}
api -> db : SELECT export_job
db --> api : ExportJob (completed)
api -> blob : Generate short-lived\nuser-specific SAS
blob --> api : Download URL (ttl=5m)
api --> app : 200 OK (downloadUrl)
app --> patient : Download FHIR Bundle

@enduml
