@startuml
skinparam defaultFontSize 11

!include <C4/C4_Component>

title FHIR Interoperability - C4 Component Diagram

Container_Boundary(fhir, "FHIR Interoperability") {

    Component(fhirApi, "FHIR API", "ASP.NET Core 9 Minimal API", "FHIR R4-compliant REST endpoints for export, import, and resource access")

    Component(exportModule, "Export Module", "CQRS Handlers", "Queues patient data export jobs and serves status checks")

    Component(exportWorker, "Export Worker", ".NET 9 Background Service", "Processes queued export jobs: gather, map, validate, package, store")

    Component(importModule, "Import Module", "CQRS Handlers", "Processes inbound FHIR Bundles and maps to internal domain models")

    Component(mapperRegistry, "FHIR Mapper Registry", "Domain Services", "Collection of resource-specific mappers: Patient, Observation, DiagnosticReport, MedicationRequest")

    Component(fhirValidator, "FHIR Validator", "Firely SDK", "Validates FHIR resources against R4 structure definitions and profiles")

    Component(smartAuthClient, "SMART on FHIR Client", "OAuth 2.0 Client", "Handles SMART launch sequences and token management for EHR connectivity")

    Component(eventConsumer, "Event Consumer", "Service Bus Subscriber", "Consumes canonical integration events idempotently to keep the FHIR resource cache current")
}

ContainerDb(postgres, "PostgreSQL", "PostgreSQL 16", "Export jobs, FHIR endpoints, mapping profiles, audit logs")

Container_Ext(blobStorage, "Azure Blob Storage", "Azure", "Stores exported FHIR Bundle files with time-limited SAS tokens")

Container_Ext(serviceBus, "Azure Service Bus", "Messaging", "Domain events from Scan, Diagnostic, Treatment, Clinical Portal")

Container_Ext(externalEhr, "External EHR", "FHIR R4 Server", "Hospital / clinic EHR systems for bidirectional sync")

Container_Ext(webApp, "Web Application", "React SPA", "Patient-facing export request UI")

Rel(webApp, fhirApi, "HTTPS", "Export requests, status checks")
Rel(fhirApi, exportModule, "MediatR", "ExportPatientDataCommand")
Rel(fhirApi, importModule, "MediatR", "ImportClinicalDataCommand")
Rel(exportModule, exportWorker, "Queue export jobs", "Background work")
Rel(exportModule, mapperRegistry, "Map", "Internal models to FHIR resources")
Rel(mapperRegistry, fhirValidator, "Validate", "Generated FHIR resources")
Rel(exportWorker, mapperRegistry, "Map", "Internal models to FHIR resources")
Rel(exportWorker, fhirValidator, "Validate", "Generated bundles")
Rel(exportWorker, blobStorage, "Azure SDK", "Upload FHIR Bundles")
Rel(exportModule, postgres, "Npgsql", "Export job tracking")
Rel(exportWorker, postgres, "Npgsql", "Update export job status")
Rel(importModule, smartAuthClient, "OAuth", "Authenticate with EHR")
Rel(smartAuthClient, externalEhr, "HTTPS", "FHIR R4 API calls")
Rel(serviceBus, eventConsumer, "Subscribe", "Domain events")
Rel(eventConsumer, postgres, "Npgsql", "Cache mapped resources")

@enduml
