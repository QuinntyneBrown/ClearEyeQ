@startuml
skinparam defaultFontSize 11
skinparam classAttributeIconSize 0
skinparam linetype ortho

title FHIR Interoperability - Application Services (CQRS + MediatR)

package "Commands" <<Rectangle>> {

    class ExportPatientDataCommand <<Command>> {
        + PatientId : Guid
        + RequestedBy : Guid
        + ResourceTypes : List<FhirResourceType>
        + Format : ExportFormat
    }

    class ProcessExportJobCommand <<Command>> {
        + JobId : Guid
    }

    class ImportClinicalDataCommand <<Command>> {
        + EndpointId : Guid
        + FhirBundle : string
        + ValidateOnly : bool
    }

    class SyncWithEhrCommand <<Command>> {
        + EndpointId : Guid
        + PatientId : Guid
        + Direction : SyncDirection
    }
}

package "Queries" <<Rectangle>> {

    class GetExportJobStatusQuery <<Query>> {
        + JobId : Guid
    }

    class GetFhirEndpointsQuery <<Query>> {
        + ActiveOnly : bool
    }
}

package "Handlers" <<Rectangle>> {

    class ExportPatientDataHandler <<Handler>> {
        - _jobs : IExportJobRepository
        --
        + Handle(command) : Result<ExportJobDto>
    }

    class ProcessExportJobHandler <<Handler>> {
        - _scanContext : IScanReadService
        - _diagnosticContext : IDiagnosticReadService
        - _treatmentContext : ITreatmentReadService
        - _mappers : IEnumerable<IFhirMapper>
        - _blobStorage : IBlobStorageService
        - _jobs : IExportJobRepository
        --
        + Handle(command) : Result
    }

    class ImportClinicalDataHandler <<Handler>> {
        + Handle(command) : Result
    }

    class SyncWithEhrHandler <<Handler>> {
        + Handle(command) : Result
    }

    class GetExportJobStatusHandler <<Handler>> {
        + Handle(query) : ExportJobDto
    }

    class GetFhirEndpointsHandler <<Handler>> {
        + Handle(query) : List<FhirEndpointDto>
    }
}

ExportPatientDataCommand --> ExportPatientDataHandler
ProcessExportJobCommand --> ProcessExportJobHandler
ImportClinicalDataCommand --> ImportClinicalDataHandler
SyncWithEhrCommand --> SyncWithEhrHandler
GetExportJobStatusQuery --> GetExportJobStatusHandler
GetFhirEndpointsQuery --> GetFhirEndpointsHandler

@enduml
