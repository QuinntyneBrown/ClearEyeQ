@startuml async-messaging
title ClearEyeQ — Azure Service Bus Event Map

skinparam rectangleRoundCorner 8
skinparam defaultFontSize 11
skinparam packageStyle rectangle

rectangle "**Scan Engine**\n(Publisher)" as scan #E3F2FD
rectangle "**Monitoring**\n(Publisher)" as monitor #E3F2FD
rectangle "**Environmental**\n(Publisher)" as env #E3F2FD
rectangle "**Diagnostic Engine**\n(Publisher)" as diag #FFF3E0
rectangle "**Predictive Engine**\n(Publisher)" as predict #FFF3E0
rectangle "**Treatment**\n(Publisher)" as treat #E8F5E9
rectangle "**Billing**\n(Publisher)" as billing #F3E5F5

queue "ScanCompleted" as q1
queue "MonitoringDataReceived" as q2
queue "EnvironmentalSnapshot" as q3
queue "DiagnosisCompleted" as q4
queue "FlareUpWarning" as q5
queue "ForecastGenerated" as q6
queue "TreatmentPlanCreated" as q7
queue "EscalationTriggered" as q8
queue "InterventionAdjusted" as q9
queue "SubscriptionChanged" as q10

rectangle "**Diagnostic Engine**\n(Subscriber)" as diagSub #FFF3E0
rectangle "**Predictive Engine**\n(Subscriber)" as predictSub #FFF3E0
rectangle "**Treatment**\n(Subscriber)" as treatSub #E8F5E9
rectangle "**Notifications**\n(Subscriber)" as notifSub #FCE4EC
rectangle "**Clinical Portal**\n(Subscriber)" as clinicSub #F5F5F5
rectangle "**All Services**\n(Subscriber)" as allSub #F5F5F5

scan --> q1
monitor --> q2
env --> q3
diag --> q4
predict --> q5
predict --> q6
treat --> q7
treat --> q8
treat --> q9
billing --> q10

q1 --> diagSub
q1 --> treatSub
q2 --> diagSub
q2 --> predictSub
q3 --> diagSub
q3 --> predictSub
q4 --> treatSub
q4 --> predictSub
q5 --> notifSub
q5 --> treatSub
q6 --> notifSub
q7 --> notifSub
q7 --> clinicSub
q8 --> notifSub
q8 --> clinicSub
q9 --> notifSub
q10 --> allSub

@enduml
