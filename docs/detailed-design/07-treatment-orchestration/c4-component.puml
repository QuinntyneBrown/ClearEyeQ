@startuml c4-component

!include <C4/C4_Component>

skinparam defaultFontSize 11

title Treatment Orchestration — C4 Component Diagram (Level 3)

Container_Boundary(treatment_service, "Treatment Orchestration Service") {

    Component(api, "Treatment API", ".NET 9 / ASP.NET Core", "REST endpoints for plan management, dose adjustment, and escalation review")

    Component(pipeline, "MediatR Pipeline", "MediatR + FluentValidation", "CQRS dispatch with validation, authorization, and logging behaviors")

    Component(handlers, "Application Handlers", "C# IRequestHandler", "CreateTreatmentPlan, AdjustDose, TrackEfficacy, EvaluateEscalation, VerifyResolution")

    Component(domain, "Domain Layer", "C# Aggregates & Services", "TreatmentPlan aggregate, EfficacyTracker, EscalationEngine, ResolutionVerifier, RelapsePreventionPlanner")

    Component(closed_loop, "Closed-Loop Processor", ".NET 9 Worker Service", "Consumes ScanCompleted and ForecastGenerated events; triggers efficacy tracking and adjustment logic")

    Component(innovation, "Innovation Workers", "Python / FastAPI", "PubMed RAG, hypothesis generation, cross-patient anonymized learning, novel formulation suggestions")

    Component(infra_cosmos, "Cosmos Repositories", "Azure Cosmos DB SDK", "CosmosTreatmentRepository for plan persistence, partitioned by UserId")
}

ContainerDb(cosmos, "Azure Cosmos DB", "NoSQL", "Treatment plans, efficacy measurements\nPartitioned by UserId")

ContainerDb(pgvector, "PostgreSQL + pgvector", "Relational + Vector", "PubMed embeddings for RAG\nliterature synthesis")

System_Ext(pharmacy, "Compounding Pharmacy API", "HTTPS REST", "Custom formulation queries and orders")

Container_Ext(service_bus, "Azure Service Bus", "Message Broker", "Domain event pub/sub")

Container_Ext(gateway, "API Gateway", "Azure APIM", "Rate limiting, TLS termination")

Container_Ext(clinical_portal, "Clinical Portal", "React SPA", "Clinician dashboard for escalations")

Rel(gateway, api, "Routes requests", "HTTPS")
Rel(api, pipeline, "Sends commands / queries")
Rel(pipeline, handlers, "Dispatches to handler")
Rel(handlers, domain, "Invokes aggregate and domain service methods")
Rel(handlers, infra_cosmos, "Persists / reads via")
Rel(handlers, innovation, "Requests formulation suggestions", "gRPC")
Rel(infra_cosmos, cosmos, "Read / Write", "SDK")
Rel(innovation, pgvector, "Vector similarity search", "SQL")
Rel(innovation, pharmacy, "Query formulations", "HTTPS")
Rel(closed_loop, service_bus, "Consumes events", "AMQP")
Rel(handlers, service_bus, "Publishes events", "AMQP")
Rel(service_bus, clinical_portal, "EscalationTriggered", "AMQP")

@enduml
