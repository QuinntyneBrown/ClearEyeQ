@startuml class-application-services
title Treatment Orchestration — Application Services

skinparam classAttributeIconSize 0
skinparam defaultFontSize 11

package "Command Handlers" {

    class CreateTreatmentRecommendationHandler <<Handler>> {
        +Handle(command) : PlanId
    }

    class ActivateTreatmentPlanHandler <<Handler>> {
        +Handle(command) : void
    }

    class TrackEfficacyHandler <<Handler>> {
        +Handle(command) : EfficacyMeasurement
    }

    class ProposeAdjustmentHandler <<Handler>> {
        +Handle(command) : AdjustmentProposalId
    }

    class ApplyApprovedAdjustmentHandler <<Handler>> {
        +Handle(command) : void
    }

    class EvaluateEscalationHandler <<Handler>> {
        +Handle(command) : EscalationDecision
    }

    class VerifyResolutionHandler <<Handler>> {
        +Handle(command) : ResolutionResult
    }
}

package "Ports" {

    interface ITreatmentRepository <<Repository>> {
        +GetByIdAsync(planId) : TreatmentPlan
        +SaveAsync(plan) : void
        +GetByUserIdAsync(tenantId, userId) : List<TreatmentPlan>
    }

    interface IEfficacyCalculator <<Service>> {
        +CalculateScore(baseline, current) : double
        +CalculateTrajectory(measurements) : Trajectory
    }

    interface IPharmacyClient <<AntiCorruptionLayer>> {
        +QueryFormulationsAsync(criteria) : List<Formulation>
        +SubmitOrderAsync(order) : OrderConfirmation
    }

    interface ISafetyGuardrailService <<Service>> {
        +ValidateRecommendation(plan) : GuardrailResult
        +CanAutoApplyBehavioralAdjustment(plan, proposal) : bool
        +CanAutoApplyMedicationChange(plan, proposal) : bool
    }

    interface IIntegrationOutbox <<Port>> {
        +Append(eventEnvelope) : void
    }

    interface IProcessedMessageStore <<Port>> {
        +TryBegin(eventId) : bool
    }
}

CreateTreatmentRecommendationHandler --> ITreatmentRepository
CreateTreatmentRecommendationHandler --> IPharmacyClient
CreateTreatmentRecommendationHandler --> ISafetyGuardrailService
CreateTreatmentRecommendationHandler --> IIntegrationOutbox
ActivateTreatmentPlanHandler --> ITreatmentRepository
ActivateTreatmentPlanHandler --> IIntegrationOutbox

TrackEfficacyHandler --> ITreatmentRepository
TrackEfficacyHandler --> IEfficacyCalculator

ProposeAdjustmentHandler --> ITreatmentRepository
ProposeAdjustmentHandler --> IEfficacyCalculator
ProposeAdjustmentHandler --> ISafetyGuardrailService
ProposeAdjustmentHandler --> IIntegrationOutbox

ApplyApprovedAdjustmentHandler --> ITreatmentRepository
ApplyApprovedAdjustmentHandler --> IIntegrationOutbox

EvaluateEscalationHandler --> ITreatmentRepository
EvaluateEscalationHandler --> IIntegrationOutbox

VerifyResolutionHandler --> ITreatmentRepository
VerifyResolutionHandler --> IEfficacyCalculator

@enduml
