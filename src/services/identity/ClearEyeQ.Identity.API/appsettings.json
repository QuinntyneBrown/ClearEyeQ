{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CosmosDb": {
    "ConnectionString": "AccountEndpoint=https://cleareyeq-cosmos.documents.azure.com:443/;AccountKey=YOUR_KEY_HERE;",
    "DatabaseName": "cleareyeq-identity"
  },
  "Jwt": {
    "Key": "YOUR_SECRET_KEY_THAT_IS_AT_LEAST_32_BYTES_LONG",
    "Issuer": "ClearEyeQ",
    "Audience": "ClearEyeQ",
    "ExpiryMinutes": "15"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  }
}
