{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "BlobStorage": "UseDevelopmentStorage=true"
  },
  "BlobStorage": {
    "ContainerName": "fhir-bundles"
  },
  "ServiceUrls": {
    "ClinicalApi": "http://localhost:5010",
    "IdentityApi": "http://localhost:5001"
  },
  "Jwt": {
    "Issuer": "ClearEyeQ",
    "Audience": "ClearEyeQ.Fhir",
    "SigningKey": "REPLACE-WITH-SECURE-KEY-AT-LEAST-32-CHARS"
  }
}
