@inherits LayoutComponentBase

<div class="layout">
    <aside class="sidebar">
        <div class="sidebar-header">
            <span class="sidebar-logo">ClearEyeQ</span>
            <span class="sidebar-badge">Admin</span>
        </div>
        <nav class="sidebar-nav">
            <NavMenu />
        </nav>
        <div style="padding: var(--space-md) var(--space-lg); border-top: 1px solid var(--color-border); font-size: 12px; color: var(--color-text-secondary);">
            v1.0.0
        </div>
    </aside>
    <div class="content-area">
        <header class="content-header">
            <h1>@PageTitle</h1>
            <div class="user-info">
                <span>&#x1F6E1; Admin</span>
            </div>
        </header>
        <main class="content-main">
            @Body
        </main>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string PageTitle => "Administration";
}
