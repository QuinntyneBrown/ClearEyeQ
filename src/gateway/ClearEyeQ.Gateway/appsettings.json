{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "https://cleareyeq.com",
    "Audience": "cleareyeq-api",
    "SigningKey": "REPLACE_WITH_SECURE_KEY_IN_PRODUCTION_MIN_32_CHARS!"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 10
  },
  "Cors": {
    "AllowedOrigins": [
      "https://app.cleareyeq.com",
      "https://portal.cleareyeq.com"
    ]
  }
}
